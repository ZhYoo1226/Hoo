    "\n  \"action\": \"meta:plan\",\n  \"thought\": \"用户对之前已接受的分析框架做进一步细化限制，属于对已有任务的澄清修正，应更新规划并确认。\",\n  \"response\": \"明白，我调整分析计划:投诉内容作为重点，行为数据限定近一个月，竞品仅关注价格变动和新增功能。按此方向推进。\",\n  \"plan\": {\n    \"name\": \"用户流失原因分析\",\n    \"task\": \"分析最近一个月用户流失的主要原因，包括用户行为、投诉记录和竞品动态。\",\n    \"task_id\": \"123456789\",\n    \"confidence\": 0.9,\n    \"steps\": [\n      \"提取近一个月用户流失前的行为特征\",\n      \"深度分析投诉文本，归类流失主因\",\n      \"监测竞品的价格调整公告与功能更新日志\",\n      \"交叉对比，给出流失主因及竞品影响权重\"\n    ]\n  ": "input",
    "\n  \"action\": \"meta:speak | meta:task | meta:plan | meta:ask\",\n  \"response\": \"根据action类型生成对应响应\",\n  \"plan\": {  // 仅当 action 为 meta:plan 时需要，否则省略\n    \"task\": \"重新根据背景信息总结任务描述。\",\n    \"task_id\": \"123456789\", // 任务 ID，用于关联任务和历史记录\n    \"steps\": [\"重新规划的步骤1\", \"步骤2\", ...]\n  ": "input",
    "  // 仅当 action 为 meta:task 时需要，否则省略\n    \"name\": \"任务名称\",\n    \"task\": \"任务的具体需求描述\",\n    \"goal\": \"任务最终要达成的目标\",\n    \"type\": \"查询统计 | 业务探索 | 搜索问答\",\n    \"steps\": [\"规划的步骤1\", \"步骤2\", ...]\n  ": "input",
